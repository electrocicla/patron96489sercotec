{
  "name": "patron96489sercotec",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma independiente para recopilar evidencia anonimizable de patrones repetidos en resultados Sercotec.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "worker:dev": "wrangler dev",
    "db:migrate:local": "wrangler d1 migrations apply evidencia_resultados --local",
    "db:migrate:remote": "wrangler d1 migrations apply evidencia_resultados --remote",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "clsx": "^2.1.1",
    "hono": "^4.10.7",
    "lucide-react": "^0.561.0",
    "next": "^16.0.7",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.68.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260606.0",
    "@eslint/eslintrc": "^3.3.3",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.7",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "wrangler": "^4.54.0"
  },
  "packageManager": "pnpm@10.33.0"
}
